# ------------------------------------------------------------------
# Remote Camera AI — reference environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit real API keys, tokens, or credentials.
# ------------------------------------------------------------------

# --- Public URLs (how clients reach the stack) ---
# For LAN use: replace "macmini.local" with your hostname or LAN IP.
# For Docker Desktop / localhost: use http://localhost:3000 / :8080.
PUBLIC_WEB_URL=http://macmini.local:3000
PUBLIC_API_URL=http://macmini.local:8080
PUBLIC_HOST=macmini.local
WEB_ORIGIN=http://macmini.local:3000

# --- WebRTC (STUN / TURN) ---
ICE_STUN_URLS=stun:stun.l.google.com:19302
# Leave ICE_TURN_URLS empty when only serving a LAN (STUN is enough).
ICE_TURN_URLS=
TURN_USERNAME=remotecam
TURN_PASSWORD=<REPLACE-WITH-STRONG-PASSWORD>
TURN_REALM=remote-camera-ai.local
TURN_EXTERNAL_IP=192.168.178.10

# --- Vision pipeline ---
VISION_TARGET_LABEL=bird
VISION_MIN_CONFIDENCE=0.30
VISION_MOTION_THRESHOLD=0.040
VISION_SERVICE_URL=http://vision:8090
VISION_MODEL=yolo26n.pt
VISION_IMG_SIZE=1280
VISION_MOTION_FRAME_WIDTH=320
VISION_ENABLE_MOTION_GATE=true
VISION_DETECT_EVERY_N_FRAMES=4
VISION_WARMUP_DETECT_FRAMES=2
VISION_TRACK_CONFIRM_FRAMES=1
VISION_TRACK_MAX_MISSED_FRAMES=20
VISION_TRACK_IOU_THRESHOLD=0.35
VISION_ROI_REFINE_ON_MOTION=true
VISION_ROI_MAX_REGIONS=2
VISION_ROI_IMG_SIZE=960
VISION_ROI_MIN_AREA_RATIO=0.002
VISION_ROI_MARGIN_RATIO=0.15
VISION_ENABLE_PRECISION_VERIFIER=true
VISION_PRECISION_MODEL=yoloe-26x-seg.pt
VISION_PRECISION_IMG_SIZE=1280
VISION_PRECISION_MIN_CONFIDENCE=0.15
VISION_PRECISION_MAX_REGIONS=3
VISION_PRECISION_REGION_MARGIN_RATIO=0.18
VISION_ENABLE_SAM3_VERIFIER=true
VISION_SAM3_MODEL=/app/extra-models/sam3.pt
VISION_SAM3_IMG_SIZE=1008
VISION_SAM3_MIN_CONFIDENCE=0.25
VISION_SAM3_MAX_REGIONS=2
VISION_SAM3_TEXT_PROMPT_LIMIT=3
VISION_TORCH_THREADS=6
VISION_ENABLE_MEGADETECTOR=true

# --- LLM narration (used for alert summaries) ---
# Provider options: gemini | claude | openai | together | stub
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite-preview
# Only populate the key matching LLM_PROVIDER. Leave the rest empty.
OPENAI_API_KEY=<REPLACE-WITH-OPENAI-KEY-OR-LEAVE-EMPTY>
GOOGLE_API_KEY=<REPLACE-WITH-GOOGLE-API-KEY-OR-LEAVE-EMPTY>
ANTHROPIC_API_KEY=<REPLACE-WITH-ANTHROPIC-KEY-OR-LEAVE-EMPTY>
TOGETHER_API_KEY=<REPLACE-WITH-TOGETHER-KEY-OR-LEAVE-EMPTY>

# --- WhatsApp alerts (whatsapp sidecar) ---
# Uses @whiskeysockets/baileys — pair once via QR on the homepage.
# No tokens required; LAN-only deployment.
WHATSAPP_ENABLED=true
WHATSAPP_SERVICE_URL=http://whatsapp:8091
WHATSAPP_COOLDOWN_MS=15000
